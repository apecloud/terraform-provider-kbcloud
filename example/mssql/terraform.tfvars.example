# ============================================================================
# Default Configuration for MSSQL Cluster
# ============================================================================
# Copy this file to terraform.tfvars and modify as needed
# DO NOT commit terraform.tfvars with sensitive information

# API Configuration (use environment variables or separate tfvars for secrets)
# api_key    = "your_api_key"
# api_secret = "your_api_secret"
# admin_api_key    = "your_admin_api_key"
# admin_api_secret = "your_admin_api_secret"

api_url = "https://kb-cloud-apiserver-endpoint.com/api"

# Cluster Basic Configuration
cluster_name     = "my-mssql-cluster"
display_name     = "my-mssql-cluster"
org_name         = "my-org"
environment_name = "prod"
project          = "kubeblocks-cloud-ns"

# Engine Configuration
engine       = "mssql"
engine_version = "2022.19.0"
mode         = "cluster"
cluster_type = "Normal"

# Network and Availability
single_zone        = true
termination_policy = "Delete"

# MSSQL Specific Configuration
certificate_custom = false
collation          = "Chinese_PRC_CI_AS"
default_db_name    = "db1"
product_edition    = "Enterprise"

# Maintenance Window
maintenance_start_hour = 18
maintenance_end_hour   = 22
maintenance_weekdays   = "1,2,3,4,5,6,7"

# Component Configuration
component_name = "mssql"
replicas       = 3
storage_size_gb = 20
storage_class  = "apelocal-rawdisk-xfs"
read_iops      = 2000
write_iops     = 2000
class_code     = "mssql.cluster.mssql.2c4g.general"

# Backup Configuration
backup_repo      = "my-backuprepo"
retention_period = "7d"
retention_policy = "LastOne"
snapshot_volumes = false

auto_backup_enabled      = true
auto_backup_method       = "full"
backup_schedule          = "0 18 * * *"

pitr_enabled             = true
continuous_backup_method = "transaction-log"

incremental_backup_enabled      = false
incremental_backup_schedule     = "0 18 * * *"

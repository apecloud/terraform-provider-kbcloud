# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
*.tfplan

# Crash log files
crash.log

# Exclude .tfvars files in root directory (likely contain sensitive data)
# But keep ops-examples/*.tfvars as they are public configuration templates
*.tfvars
!ops-examples/*.tfvars

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Vim swap files
*.swp
*.swo
*~

# eks cluster info file
script/eks.info